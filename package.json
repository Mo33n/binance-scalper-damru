{
  "name": "binance-scalper-damru",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "node --import tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:secrets": "node scripts/verify-secrets.mjs",
    "verify:rollout": "tsx scripts/verify-rollout.ts",
    "smoke:exchange-info": "tsx scripts/smoke-exchange-info.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.6"
  },
  "dependencies": {
    "pino": "^9.5.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  }
}
