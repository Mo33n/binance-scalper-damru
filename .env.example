# Copy to .env — never commit real keys.
# Prefer CONFIG_PATH + config/examples/*.json for non-secret settings.

# testnet | live (defaults to testnet)
TRADING_ENV=testnet

# Optional overrides (same shape as config file — see config/README.md)
BINANCE_REST_BASE_URL=
BINANCE_WS_BASE_URL=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Path to JSON validated by src/config/schema.ts
# CONFIG_PATH=config/examples/testnet.json

LOG_LEVEL=info
